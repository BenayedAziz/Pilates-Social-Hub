# Domain for Caddy HTTPS (used by docker-compose.prod.yml)
DOMAIN=pilateshub.com

# Database password
DB_PASSWORD=your-secure-password-here

# App port (used by docker-compose.yml — the simple deployment without Caddy)
APP_PORT=3000

# App environment
NODE_ENV=production

# Image Storage (Cloudflare R2 or S3-compatible)
S3_ENDPOINT=
S3_BUCKET=pilateshub-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
