# Domain for Caddy HTTPS (used by docker-compose.prod.yml)
DOMAIN=pilateshub.com

# Database password
DB_PASSWORD=your-secure-password-here

# App port (used by docker-compose.yml — the simple deployment without Caddy)
APP_PORT=3000

# App environment
NODE_ENV=production

# Image Storage (Cloudflare R2 or S3-compatible)
S3_ENDPOINT=
S3_BUCKET=pilateshub-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Resend (email delivery — free tier: 3,000 emails/month)
# If not set, emails are logged to console instead
RESEND_API_KEY=
EMAIL_FROM=PilatesHub <bookings@pilateshub.com>
